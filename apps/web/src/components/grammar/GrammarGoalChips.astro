---
import { communicationGoals } from "../../data/taxonomies";

const iconByGoal = {
  "hablar-del-pasado": "calendar",
  "opinar-y-argumentar": "chat",
  "formular-hipotesis": "question",
  "dar-consejos": "bulb",
  "expresar-obligacion": "alert",
  "contar-lo-que-alguien-dijo": "quote",
  "causa-y-consecuencia": "link",
};
---

<ul class="goal-chips" aria-label="Objetivos comunicativos de gramática">
  {
    communicationGoals.map((goal) => {
      const icon = iconByGoal[goal.id];
      return (
        <li>
          <a href={`/contenidos/?domain=grammar&goal=${goal.id}`}>
            <span class="goal-icon" aria-hidden="true">
              {
                icon === "calendar" ? (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M7 3v4M17 3v4M4 9h16M5 5h14v15H5z" />
                  </svg>
                ) : icon === "chat" ? (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M5 6.5A7 7 0 0 1 12 4a7 7 0 0 1 7 6.5 7 7 0 0 1-9.2 6.65L5 19l1.35-4.1A7 7 0 0 1 5 6.5Z" />
                  </svg>
                ) : icon === "question" ? (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M9.7 9a2.4 2.4 0 0 1 4.55 1.1c0 1.8-2.25 2.05-2.25 3.55M12 17h.01" />
                  </svg>
                ) : icon === "bulb" ? (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M9 18h6M10 22h4M8 14.5A6 6 0 1 1 16 14.5c-.7.65-1 1.35-1 2.5h-6c0-1.15-.3-1.85-1-2.5Z" />
                  </svg>
                ) : icon === "alert" ? (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <circle cx="12" cy="12" r="9" />
                    <path d="M12 7v6M12 17h.01" />
                  </svg>
                ) : icon === "quote" ? (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M8 10H5.5A2.5 2.5 0 0 0 3 12.5V17h5zM18 10h-2.5a2.5 2.5 0 0 0-2.5 2.5V17h5z" />
                  </svg>
                ) : (
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M10 13a5 5 0 0 0 7.07 0l2-2a5 5 0 0 0-7.07-7.07l-1.1 1.1" />
                    <path d="M14 11a5 5 0 0 0-7.07 0l-2 2A5 5 0 0 0 12 20.07l1.1-1.1" />
                  </svg>
                )
              }
            </span>
            {goal.label}
          </a>
        </li>
      );
    })
  }
</ul>

<style>
  .goal-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 0.8rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .goal-chips a {
    display: inline-flex;
    min-height: 2.3rem;
    align-items: center;
    gap: 0.6rem;
    padding: 0.42rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 0.55rem;
    background: #ffffff;
    color: var(--color-blue-dark);
    font-size: 0.84rem;
    font-weight: 800;
    max-width: 100%;
  }

  .goal-chips a:hover,
  .goal-chips a:focus-visible {
    border-color: rgba(0, 85, 164, 0.34);
  }

  .goal-chips a:focus-visible {
    outline: 3px solid rgba(184, 134, 11, 0.28);
    outline-offset: 3px;
  }

  .goal-icon {
    display: inline-flex;
    width: 1.35rem;
    height: 1.35rem;
    align-items: center;
    justify-content: center;
    color: var(--color-blue-dark);
  }

  .goal-icon svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  @media (max-width: 560px) {
    .goal-chips {
      display: grid;
      grid-template-columns: 1fr;
    }

    .goal-chips li,
    .goal-chips a {
      min-width: 0;
    }

    .goal-chips a {
      width: 100%;
      align-items: flex-start;
      line-height: 1.25;
      white-space: normal;
    }

    .goal-icon {
      flex: 0 0 auto;
    }
  }
</style>
