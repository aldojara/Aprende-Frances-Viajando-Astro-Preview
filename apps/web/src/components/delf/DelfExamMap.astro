---
const skills = [
  ["Comprensión oral", "Escuchar y entender mensajes y diálogos."],
  ["Comprensión escrita", "Leer y comprender textos de diferentes tipos."],
  ["Producción escrita", "Escribir textos claros, coherentes y adecuados."],
  ["Producción oral", "Expresarse con fluidez y corrección ante un examinador."],
];
---

<aside class="exam-map" aria-labelledby="exam-map-title">
  <h2 id="exam-map-title">Mapa del examen</h2>
  <ol>
    {
      skills.map(([title, description]) => (
        <li>
          <span aria-hidden="true"></span>
          <div>
            <h3>{title}</h3>
            <p>{description}</p>
          </div>
        </li>
      ))
    }
  </ol>
</aside>

<style>
  .exam-map {
    overflow: hidden;
    padding: 1.35rem 1.15rem;
    border: 1px solid rgba(184, 134, 11, 0.48);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 90% 8%, rgba(244, 196, 95, 0.16), transparent 28%),
      #062653;
    color: #ffffff;
    box-shadow: var(--shadow-md);
  }

  .exam-map h2 {
    color: #ffffff;
    font-size: 1.25rem;
  }

  .exam-map h2::after {
    display: block;
    width: 2rem;
    height: 2px;
    margin-top: 0.45rem;
    background: var(--color-gold);
    content: "";
  }

  .exam-map ol {
    display: grid;
    gap: 1.1rem;
    padding: 0;
    margin: 1.45rem 0 0;
    list-style: none;
  }

  .exam-map li {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.8rem;
    align-items: start;
  }

  .exam-map li + li::before {
    position: absolute;
    top: -1.1rem;
    left: 1.1rem;
    width: 1px;
    height: 1.1rem;
    border-left: 2px dashed var(--color-gold);
    content: "";
  }

  .exam-map li > span {
    display: grid;
    width: 2.3rem;
    height: 2.3rem;
    place-items: center;
    border-radius: 999px;
    background: #ffffff;
  }

  .exam-map li > span::after {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: var(--color-blue-dark);
    content: "";
  }

  .exam-map h3 {
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 900;
  }

  .exam-map p {
    margin: 0.16rem 0 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.78rem;
    line-height: 1.42;
    overflow-wrap: anywhere;
  }
</style>
