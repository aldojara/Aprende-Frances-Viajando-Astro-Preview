---
import { delfLevels } from "../../data/delfExamSpecs";
import { withBase } from "../../utils/paths";
---

<section id="explorar-por-nivel" class="level-grid-section" aria-labelledby="level-grid-title">
  <h2 id="level-grid-title">Explorar por nivel</h2>
  <ul class="level-grid">
    {
      delfLevels.map((level) => {
        const isLinked = level.level === "B1" || level.level === "B2";
        return (
          <li>
            {isLinked ? (
              <a class={`level-card level-card-${level.level.toLowerCase()}`} href={withBase(`/delf/${level.level.toLowerCase()}/`)}>
                <span class="level-code">{level.level}</span>
                <strong>DELF {level.level}</strong>
                <span>{level.levelName}</span>
                <p>{level.level === "B1" ? "Interactúa con fluidez sobre temas conocidos." : "Argumenta y se expresa con claridad y precisión."}</p>
                <em>{level.editorialStatus}</em>
                <span class="level-action">Ver nivel</span>
              </a>
            ) : (
              <article class={`level-card level-card-${level.level.toLowerCase()}`}>
                <span class="level-code">{level.level}</span>
                <strong>DELF {level.level}</strong>
                <span>{level.levelName}</span>
                <p>{level.level === "A1" ? "Selecciona y usa expresiones muy básicas." : "Comunica en situaciones cotidianas simples."}</p>
                <em>{level.editorialStatus}</em>
              </article>
            )}
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  .level-grid-section {
    display: grid;
    gap: 0.85rem;
  }

  .level-grid-section h2 {
    font-size: clamp(1.45rem, 2.5vw, 1.85rem);
  }

  .level-grid-section h2::after {
    display: block;
    width: 2rem;
    height: 2px;
    margin-top: 0.45rem;
    background: var(--color-gold);
    content: "";
  }

  .level-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .level-card {
    position: relative;
    display: grid;
    min-height: 19rem;
    align-content: start;
    overflow: hidden;
    padding: 1.35rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.68)),
      var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .level-card::after {
    position: absolute;
    right: -1rem;
    bottom: -0.2rem;
    left: 0;
    height: 4.3rem;
    background:
      linear-gradient(180deg, transparent, rgba(255, 255, 255, 0.72)),
      repeating-linear-gradient(90deg, currentColor 0 1px, transparent 1px 38px);
    opacity: 0.16;
    content: "";
  }

  a.level-card {
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  a.level-card:hover,
  a.level-card:focus-visible {
    transform: translateY(-3px);
    border-color: rgba(184, 134, 11, 0.4);
    box-shadow: var(--shadow-md);
  }

  a.level-card:focus-visible {
    outline: 3px solid rgba(184, 134, 11, 0.28);
    outline-offset: 4px;
  }

  .level-code {
    color: currentColor;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 3.7rem);
    font-weight: 800;
    line-height: 1;
  }

  .level-card strong {
    margin-top: 0.4rem;
    color: var(--color-blue-dark);
    font-family: var(--font-display);
    font-size: 1.02rem;
  }

  .level-card > span:not(.level-code):not(.level-action) {
    color: currentColor;
    font-size: 0.84rem;
    font-weight: 900;
  }

  .level-card p {
    margin: 0.75rem 0 0;
    color: var(--color-heading);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .level-card em {
    justify-self: start;
    margin-top: 1rem;
    padding: 0.28rem 0.62rem;
    border-radius: 999px;
    background: rgba(11, 47, 85, 0.08);
    color: var(--color-blue-dark);
    font-size: 0.72rem;
    font-style: normal;
    font-weight: 900;
  }

  .level-action {
    margin-top: 1rem;
    color: var(--color-blue-dark);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .level-card-a1 {
    color: #245a9a;
  }

  .level-card-a2 {
    color: #2b7a43;
  }

  .level-card-b1 {
    color: #c47f00;
  }

  .level-card-b2 {
    color: #6b53bd;
  }

  @media (max-width: 1040px) {
    .level-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .level-grid {
      grid-template-columns: 1fr;
    }

    .level-card {
      min-height: 15rem;
    }
  }
</style>
