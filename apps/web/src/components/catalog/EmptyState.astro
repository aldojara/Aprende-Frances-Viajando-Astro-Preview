---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "No hay resultados para estos filtros",
  description = "Prueba con otra combinacion de nivel, dominio, formato o estado.",
} = Astro.props;
---

<div class="empty-state" data-empty-state hidden>
  <h2>{title}</h2>
  <p>{description}</p>
</div>

<style>
  .empty-state {
    padding: 1.25rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.64);
  }

  .empty-state h2 {
    font-size: 1.35rem;
  }

  .empty-state p {
    margin: 0.55rem 0 0;
    color: var(--color-text-muted);
  }
</style>
