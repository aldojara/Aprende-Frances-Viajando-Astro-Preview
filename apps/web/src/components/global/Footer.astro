---
import {
  footerSections,
  legalLinks,
  socialChannels,
  type FooterLink,
  type SocialChannel,
} from "../../data/footer";
import { withBase } from "../../utils/paths";

const currentYear = new Date().getFullYear();

const statusClass = (status: FooterLink["status"] | SocialChannel["status"]) =>
  ({
    Disponible: "is-available",
    "En construcción": "is-building",
    "En expansión": "is-expanding",
    Próximamente: "is-upcoming",
  })[status];
---

<footer class="site-footer" aria-labelledby="site-footer-heading">
  <div class="container footer-main">
    <div class="footer-brand">
      <a class="footer-brand-link" href={withBase("/")} aria-label="Ir al inicio">
        <span class="footer-brand-mark" aria-hidden="true">AFV</span>
        <span class="footer-brand-text">
          <strong id="site-footer-heading">Aprende Francés</strong>
          <span>Viajando</span>
        </span>
      </a>

      <p>
        Aprende francés con contenido, rutas y práctica para avanzar paso a
        paso.
      </p>

      <p class="footer-brand-note">
        Plataforma editorial en evolución: nuevas rutas y recursos se activarán
        progresivamente.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Navegación secundaria">
      {
        footerSections.map((section) => (
          <section class="footer-column" aria-labelledby={`footer-${section.id}`}>
            <h2 id={`footer-${section.id}`}>{section.title}</h2>

            <ul>
              {section.links.map((link) => (
                <li>
                  {link.href ? (
                    <a
                      href={link.external ? link.href : withBase(link.href)}
                      aria-label={link.ariaLabel}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                    >
                      <span>{link.label}</span>
                      <span class={`footer-status ${statusClass(link.status)}`}>
                        {link.status}
                      </span>
                    </a>
                  ) : (
                    <span class="footer-disabled-link">
                      <span>{link.label}</span>
                      <span class={`footer-status ${statusClass(link.status)}`}>
                        {link.status}
                      </span>
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))
      }

      <section class="footer-column footer-connect" aria-labelledby="footer-connect">
        <h2 id="footer-connect">Conecta</h2>

        <ul>
          {
            socialChannels.map((channel) => (
              <li>
                {channel.href ? (
                  <a
                    href={channel.href}
                    aria-label={channel.ariaLabel || `Abrir ${channel.label}`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span class="footer-social-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" focusable="false">
                        {channel.icon === "video" && (
                          <>
                            <path d="M5 6h10a4 4 0 0 1 4 4v4a4 4 0 0 1-4 4H5z" />
                            <path d="m15 10 4-2v8l-4-2z" />
                          </>
                        )}
                        {channel.icon === "play" && (
                          <>
                            <path d="M4 7h16v10H4z" />
                            <path d="m10 9 5 3-5 3z" />
                          </>
                        )}
                        {channel.icon === "camera" && (
                          <>
                            <path d="M6 7h12v11H6z" />
                            <path d="M9 7l1-2h4l1 2" />
                            <path d="M10 12a2 2 0 1 0 4 0 2 2 0 0 0-4 0" />
                          </>
                        )}
                        {channel.icon === "article" && (
                          <>
                            <path d="M6 4h12v16H6z" />
                            <path d="M9 8h6" />
                            <path d="M9 12h6" />
                            <path d="M9 16h4" />
                          </>
                        )}
                        {channel.icon === "community" && (
                          <>
                            <path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
                            <path d="M16 12a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                            <path d="M4 19a4 4 0 0 1 8 0" />
                            <path d="M13 19a3 3 0 0 1 6 0" />
                          </>
                        )}
                      </svg>
                    </span>
                    <span>{channel.label}</span>
                    <span class={`footer-status ${statusClass(channel.status)}`}>
                      {channel.status}
                    </span>
                  </a>
                ) : (
                  <span class="footer-disabled-link">
                    <span class="footer-social-icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" focusable="false">
                        {channel.icon === "video" && (
                          <>
                            <path d="M5 6h10a4 4 0 0 1 4 4v4a4 4 0 0 1-4 4H5z" />
                            <path d="m15 10 4-2v8l-4-2z" />
                          </>
                        )}
                        {channel.icon === "play" && (
                          <>
                            <path d="M4 7h16v10H4z" />
                            <path d="m10 9 5 3-5 3z" />
                          </>
                        )}
                        {channel.icon === "camera" && (
                          <>
                            <path d="M6 7h12v11H6z" />
                            <path d="M9 7l1-2h4l1 2" />
                            <path d="M10 12a2 2 0 1 0 4 0 2 2 0 0 0-4 0" />
                          </>
                        )}
                        {channel.icon === "article" && (
                          <>
                            <path d="M6 4h12v16H6z" />
                            <path d="M9 8h6" />
                            <path d="M9 12h6" />
                            <path d="M9 16h4" />
                          </>
                        )}
                        {channel.icon === "community" && (
                          <>
                            <path d="M8 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6" />
                            <path d="M16 12a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5" />
                            <path d="M4 19a4 4 0 0 1 8 0" />
                            <path d="M13 19a3 3 0 0 1 6 0" />
                          </>
                        )}
                      </svg>
                    </span>
                    <span>{channel.label}</span>
                    <span class={`footer-status ${statusClass(channel.status)}`}>
                      {channel.status}
                    </span>
                  </span>
                )}
              </li>
            ))
          }
        </ul>
      </section>
    </nav>

    <aside class="footer-news" aria-labelledby="footer-news-heading">
      <p class="footer-news-kicker">Novedades</p>
      <h2 id="footer-news-heading">Recibe novedades del proyecto</h2>
      <p>
        La suscripción por correo estará disponible próximamente. Mientras
        tanto, las nuevas rutas se publicarán de forma progresiva en la web.
      </p>
      <span>Próximamente</span>
    </aside>
  </div>

  <div class="container footer-bottom">
    <p>© {currentYear} Aprende Francés Viajando.</p>

    <p class="footer-delf-note">
      “DELF” es una denominación oficial vinculada a France Éducation
      international. Este proyecto es independiente y no representa a dicha
      institución.
    </p>

    <div class="footer-legal" aria-label="Estado de documentación legal">
      <span>Documentación legal en preparación</span>
      <ul>
        {
          legalLinks.map((link) => (
            <li>
              <span>{link.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(239, 237, 232, 0.72)),
      var(--color-bg);
    color: var(--color-text);
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(13rem, 1.2fr) minmax(0, 2.6fr) minmax(15rem, 1fr);
    gap: 2rem;
    padding-block: 3.2rem 2.35rem;
  }

  .footer-brand {
    display: grid;
    align-content: start;
  }

  .footer-brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    justify-self: start;
  }

  .footer-brand-link:focus-visible,
  .footer-nav a:focus-visible {
    outline: 3px solid var(--color-gold);
    outline-offset: 4px;
  }

  .footer-brand-mark {
    display: grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border: 1px solid rgba(184, 134, 11, 0.35);
    border-radius: 50%;
    background: var(--color-surface);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    box-shadow: var(--shadow-sm);
  }

  .footer-brand-text {
    display: grid;
    color: var(--color-heading);
    line-height: 1.05;
  }

  .footer-brand-text strong {
    font-family: var(--font-display);
    font-size: 1.15rem;
  }

  .footer-brand-text span {
    margin-top: 0.18rem;
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .footer-brand p {
    margin: 1rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .footer-brand .footer-brand-note {
    color: var(--color-heading);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .footer-column {
    min-width: 0;
  }

  .footer-column h2,
  .footer-news h2 {
    font-family: var(--font-body);
  }

  .footer-column h2 {
    color: var(--color-heading);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-column ul,
  .footer-legal ul {
    display: grid;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer-column ul {
    margin-top: 0.78rem;
  }

  .footer-column a,
  .footer-disabled-link {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.18rem;
    min-width: 0;
    min-height: 2.12rem;
    align-content: center;
    color: var(--color-heading);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .footer-column a {
    transition: color 160ms ease;
  }

  .footer-column a:hover {
    color: var(--color-blue);
  }

  .footer-disabled-link {
    color: var(--color-text-muted);
  }

  .footer-status {
    display: inline-flex;
    justify-self: start;
    border-radius: 999px;
    font-size: 0.56rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  .footer-status.is-available {
    color: #247144;
  }

  .footer-status.is-building {
    color: var(--color-blue);
  }

  .footer-status.is-expanding {
    color: var(--color-blue);
  }

  .footer-status.is-upcoming {
    color: var(--color-gold);
  }

  .footer-connect .footer-disabled-link,
  .footer-connect a {
    grid-template-columns: auto minmax(0, 1fr);
    column-gap: 0.48rem;
  }

  .footer-connect .footer-status {
    grid-column: 2;
  }

  .footer-social-icon {
    display: grid;
    width: 1.55rem;
    height: 1.55rem;
    place-items: center;
    border: 1px solid rgba(11, 47, 85, 0.12);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.62);
    color: var(--color-heading);
  }

  .footer-social-icon svg {
    width: 1rem;
    height: 1rem;
  }

  .footer-social-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .footer-news {
    align-self: start;
    min-width: 0;
    padding: 1rem;
    border: 1px solid rgba(11, 47, 85, 0.12);
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.72);
    box-shadow: var(--shadow-sm);
  }

  .footer-news-kicker {
    margin: 0 0 0.44rem;
    color: var(--color-blue);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-news h2 {
    color: var(--color-heading);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.25;
  }

  .footer-news p {
    margin: 0.62rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.48;
  }

  .footer-news span {
    display: inline-flex;
    min-height: 1.65rem;
    align-items: center;
    margin-top: 0.82rem;
    padding: 0.18rem 0.52rem;
    border-radius: 999px;
    background: var(--color-surface-soft);
    color: var(--color-gold);
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .footer-bottom {
    display: grid;
    grid-template-columns: minmax(10rem, 0.8fr) minmax(0, 1.6fr) minmax(14rem, 1fr);
    gap: 1.2rem;
    align-items: start;
    padding-block: 1.05rem 1.45rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom p,
  .footer-legal {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .footer-bottom > p:first-child {
    color: var(--color-heading);
    font-weight: 800;
  }

  .footer-delf-note {
    max-width: 38rem;
  }

  .footer-legal {
    display: grid;
    gap: 0.5rem;
    justify-items: end;
  }

  .footer-legal > span {
    color: var(--color-heading);
    font-weight: 800;
  }

  .footer-legal ul {
    display: flex;
    flex-wrap: wrap;
    justify-content: end;
    gap: 0.4rem 0.7rem;
  }

  .footer-legal li {
    color: var(--color-text-muted);
  }

  @media (max-width: 1080px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 1.7rem;
    }

    .footer-brand {
      max-width: 42rem;
    }

    .footer-news {
      max-width: 36rem;
    }

    .footer-bottom {
      grid-template-columns: 1fr;
    }

    .footer-legal {
      justify-items: start;
    }

    .footer-legal ul {
      justify-content: start;
    }
  }

  @media (max-width: 760px) {
    .footer-main {
      padding-block: 2.5rem 1.8rem;
    }

    .footer-nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 480px) {
    .footer-main {
      gap: 1.45rem;
    }

    .footer-nav {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .footer-column a,
    .footer-disabled-link {
      min-height: 2.75rem;
    }

    .footer-news {
      padding: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-column a {
      transition: none;
    }
  }
</style>

