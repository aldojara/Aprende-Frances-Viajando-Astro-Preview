---
import ContentCard from "./ContentCard.astro";
import { recentContent } from "../../data/recentContent";
---

<section class="section recent-content" aria-labelledby="recent-content-heading">
  <div class="container recent-content-layout">
    <div class="recent-intro">
      <p class="eyebrow">Nuevos recursos</p>

      <h2 id="recent-content-heading">Contenido reciente</h2>

      <p>
        Aprende con formatos variados y auténticos.
      </p>

      <p class="recent-note">
        Contenidos demostrativos integrados al catálogo inicial.
      </p>

      <a class="recent-future-action" href="/contenidos/" aria-label="Ver catálogo completo">
        <span>Catálogo completo</span>
        <span>Disponible</span>
      </a>
    </div>

    <ul class="recent-grid" aria-label="Contenido reciente en demostración">
      {
        recentContent.map((item) => (
          <li>
            <ContentCard item={item} />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .recent-content {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .recent-content-layout {
    display: grid;
    grid-template-columns: minmax(160px, 0.22fr) minmax(0, 0.78fr);
    gap: 1.25rem;
    align-items: start;
  }

  .recent-intro {
    position: sticky;
    top: 6rem;
  }

  .recent-intro h2 {
    font-size: clamp(2rem, 3.2vw, 3rem);
  }

  .recent-intro > p {
    margin: 0.85rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.98rem;
  }

  .recent-intro .recent-note {
    font-size: 0.78rem;
    font-weight: 700;
  }

  .recent-future-action {
    display: inline-grid;
    gap: 0.22rem;
    min-height: 2.5rem;
    margin-top: 1.35rem;
    padding: 0.72rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-heading);
    font-size: 0.82rem;
    font-weight: 800;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .recent-future-action:hover {
    transform: translateY(-2px);
    border-color: rgba(0, 85, 164, 0.3);
    box-shadow: var(--shadow-sm);
  }

  .recent-future-action span + span {
    justify-self: start;
    padding: 0.18rem 0.48rem;
    border-radius: 999px;
    background: var(--color-surface-soft);
    color: #247144;
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .recent-grid > li {
    min-width: 0;
  }

  @media (max-width: 980px) {
    .recent-content-layout {
      grid-template-columns: 1fr;
    }

    .recent-intro {
      position: static;
      max-width: 720px;
    }

    .recent-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .recent-content {
      overflow: hidden;
    }

    .recent-content-layout {
      width: 100%;
      gap: 1.5rem;
    }

    .recent-intro {
      width: min(100% - 2rem, var(--container-width));
      margin-inline: auto;
    }

    .recent-grid {
      display: grid;
      grid-auto-columns: minmax(17rem, 82vw);
      grid-auto-flow: column;
      grid-template-columns: none;
      gap: 0.85rem;
      width: 100%;
      padding: 0 1rem 0.75rem;
      overflow-x: auto;
      overscroll-behavior-inline: contain;
      scroll-padding-inline: 1rem;
      scroll-snap-type: inline mandatory;
      scrollbar-width: thin;
    }

    .recent-grid > li {
      scroll-snap-align: start;
    }
  }
</style>
