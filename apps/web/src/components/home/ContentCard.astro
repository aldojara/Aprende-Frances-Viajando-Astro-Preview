---
import type { RecentContentItem } from "../../data/recentContent";
import { withBase } from "../../utils/paths";

interface Props {
  item: RecentContentItem;
}

const { item } = Astro.props;
const isAvailable = Boolean(item.status === "Disponible" && item.href);
---

{
  isAvailable ? (
    <a class="content-card card content-card-link" href={withBase(item.href)}>
      <img
        src={withBase(item.image)}
        alt={item.alt}
        width="640"
        height="420"
        loading="lazy"
        decoding="async"
      />

      <div class="content-card-body">
        <div class="content-card-top">
          <span class="format-badge">{item.format}</span>
          <span class="content-category">{item.category}</span>
        </div>

        <h3>{item.title}</h3>

        <dl class="content-meta">
          <div>
            <dt>Nivel</dt>
            <dd>{item.level}</dd>
          </div>

          <div>
            <dt>Duración</dt>
            <dd>{item.duration}</dd>
          </div>
        </dl>

        <span class="content-action">Ver contenido</span>
      </div>
    </a>
  ) : (
    <article class="content-card card">
      <img
        src={withBase(item.image)}
        alt={item.alt}
        width="640"
        height="420"
        loading="lazy"
        decoding="async"
      />

      <div class="content-card-body">
        <div class="content-card-top">
          <span class="format-badge">{item.format}</span>
          <span class="content-category">{item.category}</span>
        </div>

        <h3>{item.title}</h3>

        <dl class="content-meta">
          <div>
            <dt>Nivel</dt>
            <dd>{item.level}</dd>
          </div>

          <div>
            <dt>Duración</dt>
            <dd>{item.duration}</dd>
          </div>
        </dl>

        <div class="content-action" aria-label="Contenido demostrativo">
          <span>{item.status}</span>
        </div>
      </div>
    </article>
  )
}

<style>
  .content-card {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    overflow: hidden;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .content-card-link:focus-visible {
    outline: 3px solid var(--color-gold);
    outline-offset: 4px;
  }

  .content-card-link:hover {
    transform: translateY(-3px);
    border-color: rgba(0, 85, 164, 0.3);
    box-shadow: var(--shadow-md);
  }

  .content-card img {
    width: 100%;
    aspect-ratio: 16 / 9;
    height: 100%;
    object-fit: cover;
    background: var(--color-surface-soft);
  }

  .content-card-body {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    padding: 0.82rem;
  }

  .content-card-top {
    display: grid;
    gap: 0.32rem;
  }

  .format-badge {
    display: inline-flex;
    justify-self: start;
    min-height: 1.65rem;
    align-items: center;
    padding: 0.24rem 0.56rem;
    border-radius: 999px;
    background: var(--color-blue-dark);
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .content-category {
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 700;
  }

  .content-card h3 {
    display: -webkit-box;
    min-height: 3.78em;
    margin-top: 0.72rem;
    overflow: hidden;
    font-size: 1rem;
    line-height: 1.26;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .content-meta {
    align-self: end;
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 0.85rem 0 0;
  }

  .content-meta div {
    display: grid;
    gap: 0.12rem;
  }

  .content-meta dt {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .content-meta dd {
    margin: 0;
    color: var(--color-heading);
    font-size: 0.84rem;
    font-weight: 800;
  }

  .content-action {
    display: inline-flex;
    min-height: 1.7rem;
    align-items: center;
    justify-self: start;
    margin-top: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--color-blue-light, #ebf2fb);
    color: var(--color-blue);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (prefers-reduced-motion: reduce) {
    .content-card {
      transition: none;
    }

    .content-card-link:hover {
      transform: none;
    }
  }
</style>
