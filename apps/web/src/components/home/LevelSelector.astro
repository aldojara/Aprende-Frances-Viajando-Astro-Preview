---
const levels = [
  {
    code: "A1",
    name: "Principiante",
    description:
      "Empieza con saludos, presentaciones, vocabulario esencial y frases para situaciones cotidianas.",
    status: "En construcción",
    href: "/niveles/a1/",
  },
  {
    code: "A2",
    name: "Básico",
    description:
      "Refuerza conversaciones simples, rutinas, planes, viajes y estructuras frecuentes del francés práctico.",
    status: "En construcción",
    href: "/niveles/a2/",
  },
  {
    code: "B1",
    name: "Intermedio",
    description:
      "Gana autonomía para narrar experiencias, expresar opiniones y desenvolverte en contextos reales.",
    status: "En construcción",
    href: "/niveles/b1/",
  },
  {
    code: "B2",
    name: "Intermedio alto",
    description:
      "Mejora precisión, argumentación, comprensión de contenidos complejos y preparación avanzada.",
    status: "En construcción",
    href: "/niveles/b2/",
  },
  {
    code: "C1",
    name: "Avanzado",
    description:
      "Perfecciona fluidez, matices, producción escrita y oral para un uso flexible del idioma.",
    status: "Próximamente",
    href: "/niveles/c1/",
  },
  {
    code: "?",
    name: "No sé mi nivel",
    description:
      "Elige esta opción cuando necesites una orientación inicial antes de empezar una ruta.",
    status: "Próximamente",
    href: "/diagnostico/",
  },
];

const isAvailable = (status: string) => status === "Disponible";
---

<section class="section level-selector">
  <div class="container">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Encuentra tu punto de partida</p>

        <h2>Elige la ruta que mejor encaja contigo</h2>
      </div>

      <p>
        Cada nivel está pensado como una ruta progresiva. Mientras preparamos
        las páginas internas, puedes ver qué camino tendrá cada opción.
      </p>
    </div>

    <ul class="level-grid" aria-label="Rutas de aprendizaje por nivel">
      {
        levels.map((level) => (
          <li>
            {isAvailable(level.status) ? (
              <a class="level-card card level-card-link" href={level.href}>
                <div class="level-top">
                  <span class="level-code">{level.code}</span>

                  <span class="level-status level-status-available">
                    {level.status}
                  </span>
                </div>

                <div class="level-copy">
                  <h3>{level.name}</h3>

                  <p>{level.description}</p>
                </div>

                <span class="level-action">Ver ruta {level.href}</span>
              </a>
            ) : (
              <article class="level-card card level-card-disabled">
                <div class="level-top">
                  <span class="level-code">{level.code}</span>

                  <span
                    class:list={[
                      "level-status",
                      {
                        "level-status-building":
                          level.status === "En construcción",
                        "level-status-coming": level.status === "Próximamente",
                      },
                    ]}
                  >
                    {level.status}
                  </span>
                </div>

                <div class="level-copy">
                  <h3>{level.name}</h3>

                  <p>{level.description}</p>
                </div>

                <div class="level-action" aria-label={`Ruta prevista ${level.href}`}>
                  <span>Ruta en construcción</span>
                  <span class="level-path">{level.href}</span>
                </div>
              </article>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .level-selector {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.7fr);
    align-items: end;
    gap: 3rem;
  }

  .section-heading h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .section-heading > p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .level-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding: 0;
    margin: 3rem 0 0;
    list-style: none;
  }

  .level-card {
    display: grid;
    min-height: 280px;
    height: 100%;
    padding: 1.5rem;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .level-card-link:hover {
    transform: translateY(-3px);
    border-color: rgba(0, 85, 164, 0.3);
    box-shadow: var(--shadow-md);
  }

  .level-card-disabled {
    color: inherit;
  }

  .level-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .level-code {
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .level-status {
    display: inline-flex;
    padding: 0.28rem 0.62rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .level-status-available {
    background: #e8f4ec;
    color: #247144;
  }

  .level-status-building {
    background: var(--color-blue-light, #ebf2fb);
    color: var(--color-blue);
  }

  .level-status-coming {
    background: var(--color-gold-light, #fdf3dc);
    color: var(--color-gold);
  }

  .level-copy {
    align-self: start;
    margin-top: 2rem;
  }

  .level-copy h3 {
    font-size: 1.4rem;
  }

  .level-copy p {
    margin: 1rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.92rem;
  }

  .level-action {
    align-self: end;
    display: grid;
    gap: 0.25rem;
    margin-top: 2rem;
    color: var(--color-blue);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .level-path {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  @media (max-width: 1024px) {
    .level-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .section-heading {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .level-grid {
      grid-template-columns: 1fr;
    }

    .level-card {
      min-height: auto;
    }
  }
</style>
