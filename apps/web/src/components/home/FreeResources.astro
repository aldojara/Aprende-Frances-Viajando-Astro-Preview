---
import ResourceCard from "./ResourceCard.astro";
import { freeResources } from "../../data/freeResources";
---

<section class="section free-resources" aria-labelledby="free-resources-heading">
  <div class="container free-resources-layout">
    <div class="free-resources-intro">
      <p class="eyebrow">Recursos para avanzar</p>

      <h2 id="free-resources-heading">Recursos gratuitos</h2>

      <p>
        Descarga, imprime y sigue aprendiendo con materiales prácticos.
      </p>

      <p class="free-resources-note">
        Los primeros recursos estarán disponibles progresivamente.
      </p>
    </div>

    <ul class="free-resources-grid" aria-label="Recursos gratuitos en demostración">
      {
        freeResources.map((item) => (
          <li>
            <ResourceCard item={item} />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .free-resources {
    border-top: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(247, 244, 237, 0)),
      var(--color-bg);
  }

  .free-resources-layout {
    display: grid;
    grid-template-columns: minmax(13.5rem, 0.25fr) minmax(0, 0.75fr);
    gap: 1.25rem;
    align-items: start;
  }

  .free-resources-intro {
    position: sticky;
    top: 6rem;
  }

  .free-resources-intro h2 {
    font-size: clamp(2rem, 3.2vw, 3rem);
  }

  .free-resources-intro > p {
    margin: 0.85rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.98rem;
  }

  .free-resources-intro .free-resources-note {
    max-width: 18rem;
    font-size: 0.78rem;
    font-weight: 700;
  }

  .free-resources-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .free-resources-grid > li {
    min-width: 0;
  }

  @media (max-width: 980px) {
    .free-resources-layout {
      grid-template-columns: 1fr;
    }

    .free-resources-intro {
      position: static;
      max-width: 720px;
    }

    .free-resources-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .free-resources-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .free-resources {
      overflow: hidden;
    }

    .free-resources-layout {
      width: 100%;
      gap: 1.5rem;
    }

    .free-resources-intro {
      width: min(100% - 2rem, var(--container-width));
      margin-inline: auto;
    }

    .free-resources-grid {
      grid-auto-columns: minmax(17rem, 82vw);
      grid-auto-flow: column;
      grid-template-columns: none;
      gap: 0.85rem;
      width: 100%;
      padding: 0 1rem 0.75rem;
      overflow-x: auto;
      overscroll-behavior-inline: contain;
      scroll-padding-inline: 1rem;
      scroll-snap-type: inline mandatory;
      scrollbar-width: thin;
    }

    .free-resources-grid > li {
      scroll-snap-align: start;
    }
  }
</style>
