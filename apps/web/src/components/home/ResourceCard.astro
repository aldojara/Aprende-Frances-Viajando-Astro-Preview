---
import type { FreeResourceItem } from "../../data/freeResources";

interface Props {
  item: FreeResourceItem;
}

const { item } = Astro.props;
const resourceUrl = item.file || item.href || "";
const isAvailable = item.status === "Disponible" && Boolean(resourceUrl);
const statusClass = item.status === "Próximamente" ? "is-upcoming" : "is-demo";
---

{
  isAvailable ? (
    <a
      class="resource-card card resource-card-link"
      href={resourceUrl}
      download={item.file ? true : undefined}
    >
      <span class="resource-visual" aria-hidden="true">
        <span class="resource-icon">
          <svg viewBox="0 0 48 48" focusable="false">
            <path d="M13 8h17l7 7v25H13z" />
            <path d="M30 8v8h7" />
            <path d="M18 24h12" />
            <path d="M18 30h16" />
          </svg>
        </span>
      </span>

      <div class="resource-card-body">
        <div class="resource-card-top">
          <span>{item.type}</span>
          <span class={`resource-status ${statusClass}`}>{item.status}</span>
        </div>

        <h3>{item.title}</h3>

        <p>{item.description}</p>

        <dl class="resource-meta">
          <div>
            <dt>Formato</dt>
            <dd>{item.format}</dd>
          </div>

          <div>
            <dt>Nivel</dt>
            <dd>{item.level}</dd>
          </div>
        </dl>

        <span class="resource-action">{item.downloadLabel || "Descargar"}</span>
      </div>
    </a>
  ) : (
    <article class="resource-card card" aria-label={`${item.title}. ${item.status}`}>
      <span class="resource-visual" aria-hidden="true">
        <span class="resource-icon">
          <svg viewBox="0 0 48 48" focusable="false">
            <path d="M13 8h17l7 7v25H13z" />
            <path d="M30 8v8h7" />
            <path d="M18 24h12" />
            <path d="M18 30h16" />
          </svg>
        </span>
      </span>

      <div class="resource-card-body">
        <div class="resource-card-top">
          <span>{item.type}</span>
          <span class={`resource-status ${statusClass}`}>{item.status}</span>
        </div>

        <h3>{item.title}</h3>

        <p>{item.description}</p>

        <dl class="resource-meta">
          <div>
            <dt>Formato</dt>
            <dd>{item.format}</dd>
          </div>

          <div>
            <dt>Nivel</dt>
            <dd>{item.level}</dd>
          </div>
        </dl>

        <span class="resource-action resource-action-muted">
          {item.downloadLabel || item.status}
        </span>
      </div>
    </article>
  )
}

<style>
  .resource-card {
    display: grid;
    grid-template-rows: auto 1fr;
    min-height: 100%;
    overflow: hidden;
  }

  .resource-card-link {
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .resource-card-link:focus-visible {
    outline: 3px solid var(--color-gold);
    outline-offset: 4px;
  }

  .resource-card-link:hover {
    transform: translateY(-3px);
    border-color: rgba(0, 85, 164, 0.3);
    box-shadow: var(--shadow-md);
  }

  .resource-visual {
    display: grid;
    min-height: 4.35rem;
    place-items: center;
    background:
      linear-gradient(135deg, rgba(0, 85, 164, 0.1), rgba(184, 134, 11, 0.14)),
      var(--color-surface-soft);
  }

  .resource-icon {
    display: grid;
    width: 3.15rem;
    height: 3.15rem;
    place-items: center;
    border: 1px solid rgba(11, 47, 85, 0.14);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.76);
    color: var(--color-blue-dark);
  }

  .resource-icon svg {
    width: 2rem;
    height: 2rem;
  }

  .resource-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.4;
  }

  .resource-card-body {
    display: grid;
    grid-template-rows: auto auto 1fr auto auto;
    padding: 0.82rem;
  }

  .resource-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
    color: var(--color-text-muted);
    font-size: 0.68rem;
    font-weight: 800;
  }

  .resource-status {
    display: inline-flex;
    min-height: 1.45rem;
    align-items: center;
    padding: 0.16rem 0.46rem;
    border-radius: 999px;
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .resource-status.is-demo {
    background: rgba(0, 85, 164, 0.1);
    color: var(--color-blue);
  }

  .resource-status.is-upcoming {
    background: var(--color-surface-soft);
    color: var(--color-gold);
  }

  .resource-card h3 {
    display: -webkit-box;
    min-height: 2.58em;
    margin-top: 0.72rem;
    overflow: hidden;
    font-size: 1rem;
    line-height: 1.29;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .resource-card p {
    display: -webkit-box;
    margin: 0.55rem 0 0;
    overflow: hidden;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .resource-meta {
    align-self: end;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
    margin: 0.82rem 0 0;
  }

  .resource-meta div {
    display: grid;
    gap: 0.08rem;
  }

  .resource-meta dt {
    color: var(--color-text-muted);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .resource-meta dd {
    margin: 0;
    color: var(--color-heading);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .resource-action {
    display: inline-flex;
    min-height: 1.75rem;
    align-items: center;
    justify-self: start;
    margin-top: 0.78rem;
    padding: 0.22rem 0.52rem;
    border-radius: 999px;
    background: var(--color-blue-dark);
    color: #ffffff;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .resource-action-muted {
    background: transparent;
    color: var(--color-text-muted);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }

  @media (max-width: 1100px) {
    .resource-card-body {
      padding: 0.78rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .resource-card-link {
      transition: none;
    }

    .resource-card-link:hover {
      transform: none;
    }
  }
</style>
