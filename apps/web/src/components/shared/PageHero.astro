---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="page-hero">
  <div class="container page-hero-inner">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{description}</p>
  </div>
</section>

<style>
  .page-hero {
    border-bottom: 1px solid var(--color-border);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.58), rgba(247, 244, 237, 0)),
      var(--color-bg);
  }

  .page-hero-inner {
    max-width: 860px;
    padding-block: 4.25rem 3.25rem;
  }

  .page-hero h1 {
    max-width: 820px;
    font-size: clamp(2.35rem, 4.6vw, 4.25rem);
  }

  .page-hero p:not(.eyebrow) {
    max-width: 720px;
    margin: 1rem 0 0;
    color: var(--color-text-muted);
    font-size: 1.06rem;
  }

  @media (max-width: 700px) {
    .page-hero-inner {
      padding-block: 3.25rem 2.5rem;
    }
  }
</style>
