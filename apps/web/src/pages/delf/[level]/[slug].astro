const defaultToc = [
  { id: "objetivo", label: "Objetivo" },
  { id: "estrategia-de-preparacion", label: "Estrategia" },
  { id: "errores-frecuentes", label: "Errores frecuentes" },
  { id: "recursos-relacionados", label: "Recursos relacionados" },
  { id: "siguiente-paso", label: "Siguiente paso" },
];

export async function getStaticPaths() {
  const entries = (await getCollection("content"))
    .filter(
      (item) =>
        item.data.domain === "delf" &&
        item.data.publicationStatus === "published" &&
        item.data.demonstration === false &&
        (item.data.levels.includes("B1") || item.data.levels.includes("B2")),
    )
    .sort((a, b) => (a.data.examOrder ?? 999) - (b.data.examOrder ?? 999));

  return entries.map((entry) => ({
    params: {
      level: getDelfContentLevel(entry),
      slug: getFinalContentSlug(entry.id),
    },
    props: {
      entry,
      allEntries: entries,
    },
  }));
}

const { entry, allEntries } = Astro.props;
const { Content } = await render(entry);
const level = entry.data.levels.find((item: string) => item === "B1" || item === "B2");
const spec = delfExamSpecs[level as "B1" | "B2"];
const relatedItems = allEntries.filter((item: any) =>
  entry.data.relatedContent.includes(item.id as any),
);
const nextItem = entry.data.nextContent
  ? allEntries.find((item: any) => item.id === entry.data.nextContent)
  : undefined;
const toc = tocById[entry.id] ?? defaultToc;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <DelfArticleLayout
    entry={entry}
    spec={spec}
    toc={toc}
    relatedItems={relatedItems}
    nextItem={nextItem}
  >
    <Content />
  </DelfArticleLayout>
</BaseLayout>
